render_port_lines() {
    local proto="$1"
    local csv="$2"

    if [[ -z "$csv" ]]; then
        echo "  (none)"
        return 0
    fi

    python3 - "$proto" "$csv" "${BPF_PIN_DIR}/syn_rate_ports" "${BPF_PIN_DIR}/udp_rate_ports" <<'PY'
import socket
import sys
import os

proto = sys.argv[1]
csv = sys.argv[2]
syn_rate_map_path = sys.argv[3] if len(sys.argv) > 3 else ""
udp_rate_map_path = sys.argv[4] if len(sys.argv) > 4 else ""
try:
    ports = [int(p) for p in csv.split(",") if p]
    proc_by_port = {p: set() for p in ports}

    def _parse_proc_net(path, state_filter, check_no_remote=False):
        result = {}
        try:
            with open(path) as f:
                next(f)
                for line in f:
                    parts = line.split()
                    if len(parts) < 10:
                        continue
                    local, remote, st, inode_str = parts[1], parts[2], parts[3], parts[9]
                    if st != state_filter:
                        continue
                    if check_no_remote and not remote.endswith(':0000'):
                        continue
                    port = int(local.split(':')[1], 16)
                    if port > 0:
                        result[port] = int(inode_str)
        except Exception:
            pass
        return result

    if proto == "tcp":
        port_to_inode = {}
        port_to_inode.update(_parse_proc_net('/proc/net/tcp', '0A'))
        port_to_inode.update(_parse_proc_net('/proc/net/tcp6', '0A'))
    else:
        port_to_inode = {}
        port_to_inode.update(_parse_proc_net('/proc/net/udp', '07', check_no_remote=True))
        port_to_inode.update(_parse_proc_net('/proc/net/udp6', '07', check_no_remote=True))

    wanted_inodes = {inode for port, inode in port_to_inode.items() if port in proc_by_port}
    inode_map = {}
    if wanted_inodes:
        try:
            for entry in os.scandir('/proc'):
                if not entry.name.isdigit():
                    continue
                pid = entry.name
                try:
                    for fd_entry in os.scandir(f'/proc/{pid}/fd'):
                        try:
                            link = os.readlink(fd_entry.path)
                            if link.startswith('socket:['):
                                inode = int(link[8:-1])
                                if inode in wanted_inodes:
                                    with open(f'/proc/{pid}/comm') as cf:
                                        inode_map[inode] = cf.read().strip()
                                    wanted_inodes.discard(inode)
                        except Exception:
                            pass
                except Exception:
                    pass
                if not wanted_inodes:
                    break
        except Exception:
            pass

    for port, inode in port_to_inode.items():
        if port in proc_by_port and inode in inode_map:
            proc_by_port[port].add(inode_map[inode])

    import subprocess
    import json as _json

    def _b(v):
        if isinstance(v, int):
            return v & 0xFF
        if isinstance(v, str):
            try:
                return int(v, 0) & 0xFF
            except ValueError:
                return 0
        return 0

    def _read_rate_map(path):
        rates = {}
        if not (path and os.path.exists(path)):
            return rates
        try:
            out = subprocess.check_output(
                ["bpftool", "-j", "map", "dump", "pinned", path],
                stderr=subprocess.DEVNULL,
            )
            for row in _json.loads(out):
                key = row.get("key", [])
                val = row.get("value", [])
                if isinstance(key, list) and len(key) >= 4:
                    port = _b(key[0]) | (_b(key[1]) << 8) | (_b(key[2]) << 16) | (_b(key[3]) << 24)
                    if isinstance(val, list) and len(val) >= 4:
                        rate = _b(val[0]) | (_b(val[1]) << 8) | (_b(val[2]) << 16) | (_b(val[3]) << 24)
                        if rate > 0:
                            rates[port] = rate
        except Exception:
            pass
        return rates

    rate_map_path = syn_rate_map_path if proto == "tcp" else udp_rate_map_path
    port_rates = _read_rate_map(rate_map_path)

    for p in sorted(set(ports)):
        try:
            svc = socket.getservbyport(p, proto)
        except Exception:
            svc = "-"
        procs = ",".join(sorted(proc_by_port.get(p, set()))) or "-"
        rate = port_rates.get(p)
        rate_str = f"{rate}/s" if rate else "-"
        print(f"  {p:5d}  {svc:<14}  {procs:<14}  {rate_str}")
except KeyboardInterrupt:
    sys.exit(130)
PY
}

collect_port_targets() {
    case "$BACKEND" in
        xdp)
            readarray -t _ports < <(read_xdp_ports)
            ;;
        nftables)
            readarray -t _ports < <(read_nft_ports)
            ;;
        *)
            echo "No active backend detected." >&2
            exit 1
            ;;
    esac

    PORTS_TCP="${_ports[0]:-}"
    PORTS_UDP="${_ports[1]:-}"
}

csv_to_sorted_lines() {
    local csv="$1"
    if [[ -z "$csv" ]]; then
        return 0
    fi
    printf '%s\n' "${csv//,/ }" | tr ' ' '\n' | sed '/^$/d' | sort -n
}

diff_csv() {
    local old_csv="$1"
    local new_csv="$2"
    local mode="$3" # added|removed
    case "$mode" in
        added)
            comm -13 <(csv_to_sorted_lines "$old_csv") <(csv_to_sorted_lines "$new_csv") | tr '\n' ' ' | sed 's/ $//'
            ;;
        removed)
            comm -23 <(csv_to_sorted_lines "$old_csv") <(csv_to_sorted_lines "$new_csv") | tr '\n' ' ' | sed 's/ $//'
            ;;
    esac
}

run_ports() {
    local tcp_ports="" udp_ports=""
    local prev_tcp="" prev_udp=""
    local added_tcp removed_tcp added_udp removed_udp
    local now_ts

    parse_ports_args "$@"
    load_config
    autodetect_iface
    detect_backend
    collect_port_targets
    tcp_ports="$PORTS_TCP"
    udp_ports="$PORTS_UDP"

    printf 'Backend   : %s\n' "$BACKEND"
    printf 'Interface : %s\n' "$IFACE"
    printf 'TCP allow :\n'
    render_port_lines tcp "$tcp_ports"
    printf 'UDP allow :\n'
    render_port_lines udp "$udp_ports"

    if [[ $PORTS_WATCH -eq 0 ]]; then
        return 0
    fi

    prev_tcp="$tcp_ports"
    prev_udp="$udp_ports"
    while true; do
        sleep "$PORTS_INTERVAL"
        detect_backend
        collect_port_targets
        tcp_ports="$PORTS_TCP"
        udp_ports="$PORTS_UDP"

        if [[ "$tcp_ports" == "$prev_tcp" && "$udp_ports" == "$prev_udp" ]]; then
            continue
        fi

        now_ts=$(date '+%Y-%m-%d %H:%M:%S')
        added_tcp=$(diff_csv "$prev_tcp" "$tcp_ports" added)
        removed_tcp=$(diff_csv "$prev_tcp" "$tcp_ports" removed)
        added_udp=$(diff_csv "$prev_udp" "$udp_ports" added)
        removed_udp=$(diff_csv "$prev_udp" "$udp_ports" removed)

        echo ""
        printf '[%s] Port whitelist updated\n' "$now_ts"
        [[ -n "$added_tcp" ]] && printf '  TCP + %s\n' "$added_tcp"
        [[ -n "$removed_tcp" ]] && printf '  TCP - %s\n' "$removed_tcp"
        [[ -n "$added_udp" ]] && printf '  UDP + %s\n' "$added_udp"
        [[ -n "$removed_udp" ]] && printf '  UDP - %s\n' "$removed_udp"
        echo ""
        printf 'TCP allow :\n'
        render_port_lines tcp "$tcp_ports"
        printf 'UDP allow :\n'
        render_port_lines udp "$udp_ports"

        prev_tcp="$tcp_ports"
        prev_udp="$udp_ports"
    done
}

collect_rows() {
    local name packets bytes

    BACKEND=""
    detect_backend

    CUR_PACKETS=()
    CUR_BYTES=()
    ROW_ORDER=()

    while IFS='|' read -r name packets bytes; do
        [[ -n "$name" ]] || continue
        ROW_ORDER+=("$name")
        CUR_PACKETS["$name"]="$packets"
        CUR_BYTES["$name"]="$bytes"
    done < <(
        case "$BACKEND" in
            xdp)
                read_xdp_rows
                ;;
            nftables)
                read_nft_rows
                ;;
        esac
        read_iface_row
    )
}

copy_current_to_prev() {
    local key
    PREV_PACKETS=()
    PREV_BYTES=()
    for key in "${!CUR_PACKETS[@]}"; do
        PREV_PACKETS["$key"]="${CUR_PACKETS[$key]}"
        PREV_BYTES["$key"]="${CUR_BYTES[$key]}"
    done
}

print_separator() {
    printf '%-12s  %-15s  %-12s' "Metric" "Packets" "Bytes"
    if [[ $SHOW_RATES -eq 1 ]]; then
        printf '  %-24s' "Rate"
    fi
    printf '\n'
    printf '%-12s  %-15s  %-12s' "------------" "---------------" "------------"
    if [[ $SHOW_RATES -eq 1 ]]; then
        printf '  %-24s' "------------------------"
    fi
    printf '\n'
}

render_stats() {
    local elapsed="$1"
    local row packets bytes packet_delta byte_delta rate

    printf 'Backend   : %s\n' "$BACKEND"
    printf 'Interface : %s\n' "$IFACE"
    printf 'Updated   : %s\n' "$(date '+%Y-%m-%d %H:%M:%S')"
    printf '\n'

    print_separator

    for row in "${ROW_ORDER[@]}"; do
        packets="${CUR_PACKETS[$row]}"
        bytes="${CUR_BYTES[$row]}"

        printf '%-12s  %-15s  %-12s' \
            "$row" \
            "$packets" \
            "$(human_bytes "$bytes")"

        if [[ $SHOW_RATES -eq 1 ]]; then
            if [[ -n "${PREV_PACKETS[$row]:-}" ]]; then
                packet_delta=$(( packets - PREV_PACKETS["$row"] ))
                if (( packet_delta < 0 )); then
                    packet_delta=-1
                fi

                if [[ "$bytes" == "-1" || "${PREV_BYTES[$row]:--1}" == "-1" ]]; then
                    byte_delta=-1
                else
                    byte_delta=$(( bytes - PREV_BYTES["$row"] ))
                    if (( byte_delta < 0 )); then
                        byte_delta=-1
                    fi
                fi

                rate=$(format_rate "$packet_delta" "$byte_delta" "$elapsed")
            else
                rate="-"
            fi

            printf '  %-24s' "$rate"
        fi

        printf '\n'
    done
}

run_stats() {
    local prev_ts cur_ts elapsed

    parse_stats_args "$@"
    load_config
    autodetect_iface

    if [[ $WATCH_MODE -eq 1 ]]; then
        if [[ $SHOW_RATES -eq 1 ]]; then
            collect_rows
            copy_current_to_prev
            prev_ts=$(read -r ts _ < /proc/uptime && echo "$ts")
        fi

        printf '\033[H\033[2J'
        while true; do
            if [[ $SHOW_RATES -eq 1 ]]; then
                sleep "$INTERVAL"
                cur_ts=$(read -r ts _ < /proc/uptime && echo "$ts")
                collect_rows
                elapsed=$(awk -v a="$cur_ts" -v b="$prev_ts" 'BEGIN { printf "%.6f", a - b }')
            else
                collect_rows
                elapsed=0
            fi

            printf '\033[H'
            render_stats "$elapsed"
            printf '\033[J'

            if [[ $SHOW_RATES -eq 1 ]]; then
                copy_current_to_prev
                prev_ts="$cur_ts"
            else
                sleep "$INTERVAL"
            fi
        done
    fi

    if [[ $SHOW_RATES -eq 1 ]]; then
        collect_rows
        copy_current_to_prev
        prev_ts=$(read -r ts _ < /proc/uptime && echo "$ts")
        sleep "$INTERVAL"
        cur_ts=$(read -r ts _ < /proc/uptime && echo "$ts")
        collect_rows
        elapsed=$(awk -v a="$cur_ts" -v b="$prev_ts" 'BEGIN { printf "%.6f", a - b }')
        render_stats "$elapsed"
        return 0
    fi

    collect_rows
    render_stats 0
}

run_check_update() {
    local force=0

    while [[ $# -gt 0 ]]; do
        case "$1" in
            --force|-f) force=1; shift ;;
            -h|--help)
                printf 'Usage: axdp check-update [--force]\n'
                printf '  --force   Apply all updates without prompting\n'
                exit 0
                ;;
            *)
                printf 'Unknown option: %s\n' "$1" >&2
                exit 1
                ;;
        esac
    done

    command -v curl >/dev/null 2>&1 || { printf 'curl is required for check-update\n' >&2; exit 1; }

    local setup_url="https://raw.githubusercontent.com/Kookiejarz/Auto_XDP/refs/heads/main/setup_xdp.sh"
    local tmp_setup
    tmp_setup=$(mktemp)
    trap 'rm -f "$tmp_setup"' EXIT

    printf 'Fetching setup_xdp.sh from GitHub...\n'
    if ! curl --proto '=https' --tlsv1.2 -sSfL "$setup_url" -o "$tmp_setup"; then
        printf 'Failed to fetch setup_xdp.sh\n' >&2
        exit 1
    fi

    if [[ $force -eq 1 ]]; then
        bash "$tmp_setup" --check-update --force
    else
        bash "$tmp_setup" --check-update
    fi
}


# TOML config management helpers
# Reload the running daemon via SIGHUP (no restart gap), or restart as fallback.
reload_daemon() {
    local pid
    if pid=$(systemctl show -p MainPID --value "$SERVICE_NAME" 2>/dev/null) && [[ "$pid" -gt 1 ]]; then
        kill -HUP "$pid" 2>/dev/null && return 0
    fi
    if command -v rc-service >/dev/null 2>&1; then
        rc-service "$SERVICE_NAME" restart 2>/dev/null && return 0
    fi
    command -v systemctl >/dev/null 2>&1 && systemctl restart "$SERVICE_NAME" 2>/dev/null || true
}

run_config() {
    local sub="${1:-show}"
    shift || true
    case "$sub" in
        show)
            run_admin_config config show "$@"
            ;;
        init)
            run_admin_config config init "$@"
            ;;
        -h|--help)
            echo "Usage: axdp config show|init"
            ;;
        *)
            echo "Unknown config subcommand: $sub" >&2; exit 1 ;;
    esac
}

run_trust() {
    local sub="${1:-list}"
    shift || true
    case "$sub" in
        list)
            run_admin_config trust list
            ;;
        add)
            [[ -f "$TOML_CONFIG" ]] || run_config init
            run_admin_config trust add "$@"
            reload_daemon
            ;;
        del)
            run_admin_config trust del "$@"
            reload_daemon
            ;;
        -h|--help)
            echo "Usage: axdp trust list|add CIDR [LABEL]|del CIDR"
            ;;
        *)
            echo "Unknown trust subcommand: $sub" >&2; exit 1 ;;
    esac
}

run_acl() {
    local sub="${1:-list}"
    shift || true
    case "$sub" in
        list)
            run_admin_config acl list
            ;;
        add)
            [[ -f "$TOML_CONFIG" ]] || run_config init
            run_admin_config acl add "$@"
            reload_daemon
            ;;
        del)
            run_admin_config acl del "$@"
            reload_daemon
            ;;
        -h|--help)
            echo "Usage: axdp acl list|add PROTO CIDR PORT...|del PROTO CIDR"
            ;;
        *)
            echo "Unknown acl subcommand: $sub" >&2; exit 1 ;;
    esac
}

run_permanent() {
    local sub="${1:-list}"
    shift || true
    case "$sub" in
        list)
            run_admin_config permanent list
            ;;
        add)
            [[ -f "$TOML_CONFIG" ]] || run_config init
            run_admin_config permanent add "$@"
            reload_daemon
            ;;
        del)
            run_admin_config permanent del "$@"
            reload_daemon
            ;;
        -h|--help)
            echo "Usage: axdp permanent list|add tcp|udp|sctp PORT [LABEL]|del tcp|udp|sctp PORT"
            ;;
        *)
            echo "Unknown permanent subcommand: $sub" >&2; exit 1 ;;
    esac
}

run_slot() {
    local sub="${1:-list}"
    shift || true

    case "$sub" in
        list|load|unload)
            run_admin_config slot "$sub" "$@"
            ;;
        *)
            echo "Usage: axdp slot list|load NAME|PROTO [PATH]|unload NAME|PROTO" >&2
            exit 1
            ;;
    esac
}

main() {
    local cmd="${1:-stats}"

    case "$cmd" in
        stats)
            shift || true
            run_stats "$@"
            ;;
        watch)
            shift || true
            run_stats --watch "$@"
            ;;
        ports)
            shift || true
            run_ports "$@"
            ;;
        backend)
            shift || true
            run_backend "$@"
            ;;
        conntrack)
            shift || true
            run_conntrack "$@"
            ;;
        sync)
            shift || true
            ensure_installed "$RUNNER_SCRIPT"
            exec "$RUNNER_SCRIPT" --sync-once "$@"
            ;;
        check-update)
            shift || true
            run_check_update "$@"
            ;;
        log-level)
            shift || true
            run_log_level "$@"
            ;;
        config)
            shift || true
            run_config "$@"
            ;;
        trust)
            shift || true
            run_trust "$@"
            ;;
        acl)
            shift || true
            run_acl "$@"
            ;;
        permanent)
            shift || true
            run_permanent "$@"
            ;;
        slot)
            shift || true
            run_slot "$@"
            ;;
        start|stop|restart|status)
            shift || true
            run_service_cmd "$cmd"
            ;;
        help|-h|--help)
            usage
            ;;
        *)
            run_stats "$@"
            ;;
    esac
}

if [[ "${BASH_SOURCE[0]:-}" == "$0" ]]; then
    main "$@"
fi

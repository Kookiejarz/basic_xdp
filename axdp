}

run_service_cmd() {
    local action="$1"

    if command -v systemctl >/dev/null 2>&1 && [[ -d "$SYSTEMD_RUN_DIR" ]]; then
        exec systemctl "$action" "$SERVICE_NAME"
    fi

    if command -v rc-service >/dev/null 2>&1; then
        exec rc-service "$SERVICE_NAME" "$action"
    fi

    echo "No supported init system detected for service control." >&2
    exit 1
}

ensure_installed() {
    local path="$1"
    [[ -x "$path" ]] || {
        echo "Missing executable: $path" >&2
        exit 1
    }
}

parse_stats_args() {
    while [[ $# -gt 0 ]]; do
        case "$1" in
            --watch)
                WATCH_MODE=1
                shift
                ;;
            --rates)
                SHOW_RATES=1
                shift
                ;;
            --interval)
                [[ $# -ge 2 ]] || {
                    echo "Missing value for --interval" >&2
                    exit 1
                }
                INTERVAL="$2"
                shift 2
                ;;
            --interface)
                [[ $# -ge 2 ]] || {
                    echo "Missing value for --interface" >&2
                    exit 1
                }
                IFACE="$2"
                shift 2
                ;;
            -h|--help)
                usage
                exit 0
                ;;
            *)
                echo "Unknown stats option: $1" >&2
                exit 1
                ;;
        esac
    done
}

load_config() {
    local cli_iface="$IFACE"
    if [[ -f "$CONFIG_FILE" ]]; then
        # shellcheck disable=SC1091
        source "$CONFIG_FILE"
    fi
    if [[ -n "$cli_iface" ]]; then
        IFACE="$cli_iface"
    fi
}

run_admin_config() {
    python3 -m auto_xdp.admin_cli \
        --config "$TOML_CONFIG" \
        --bpf-pin-dir "$BPF_PIN_DIR" \
        --install-dir "$INSTALL_DIR" \
        "$@"
}

run_admin_runtime() {
    python3 -m auto_xdp.admin.main \
        --env-config "$CONFIG_FILE" \
        --bpf-pin-dir "$BPF_PIN_DIR" \
        --run-state-dir "$RUN_STATE_DIR" \
        --nft-family "$NFT_FAMILY" \
        --nft-table "$NFT_TABLE" \
        "$@"
}

valid_log_level() {
    case "$1" in
        debug|info|warning|error)
            return 0
            ;;
        *)
            return 1
            ;;
    esac
}

set_config_var() {
    local key="$1"
    local value="$2"
    local tmp_file=""

    [[ -f "$CONFIG_FILE" ]] || {
        echo "Missing config: $CONFIG_FILE" >&2
        exit 1
    }

    tmp_file=$(mktemp)
    awk -v key="$key" -v value="$value" '
    BEGIN { updated = 0 }
    $0 ~ ("^" key "=") {
        print key "=\"" value "\""
        updated = 1
        next
    }
    { print }
    END {
        if (!updated)
            print key "=\"" value "\""
    }' "$CONFIG_FILE" > "$tmp_file"
    mv "$tmp_file" "$CONFIG_FILE"
}

run_log_level() {
    local level="${1:-}"

    if [[ -z "$level" ]]; then
        run_admin_config log-level
        return $?
    fi

    [[ -f "$TOML_CONFIG" ]] || run_config init
    run_admin_config log-level "$level"
    reload_daemon
    return 0
}

autodetect_iface() {
    if [[ -n "$IFACE" ]]; then
        return 0
    fi

    IFACE="${IFACE:-}"
    if [[ -z "$IFACE" ]]; then
        IFACE=$(ip route show default 2>/dev/null | awk '/default/ {print $5; exit}')
    fi

    [[ -n "$IFACE" ]] || {
        echo "Could not detect interface. Use --interface IFACE." >&2
        exit 1
    }
}

detect_backend() {
    local candidate=""

    if [[ -f "${RUN_STATE_DIR}/backend" ]]; then
        candidate=$(<"${RUN_STATE_DIR}/backend")
    fi

    case "$candidate" in
        xdp)
            if [[ -e "${BPF_PIN_DIR}/pkt_counters" ]] || ip -d link show dev "$IFACE" 2>/dev/null | grep -Eq 'xdp|xdpgeneric|xdpoffload'; then
                BACKEND="xdp"
                return 0
            fi
            ;;
        nftables)
            if command -v nft &>/dev/null && nft list table "$NFT_FAMILY" "$NFT_TABLE" >/dev/null 2>&1; then
                BACKEND="nftables"
                return 0
            fi
            ;;
    esac

    if [[ -e "${BPF_PIN_DIR}/pkt_counters" ]] && ip -d link show dev "$IFACE" 2>/dev/null | grep -Eq 'xdp|xdpgeneric|xdpoffload'; then
        BACKEND="xdp"
        return 0
    fi

    if command -v nft &>/dev/null && nft list table "$NFT_FAMILY" "$NFT_TABLE" >/dev/null 2>&1; then
        BACKEND="nftables"
        return 0
    fi

    if [[ -e "${BPF_PIN_DIR}/pkt_counters" ]]; then
        BACKEND="xdp"
        return 0
    fi

    echo "No active Auto XDP backend detected." >&2
    exit 1
}

configured_ifaces() {
    if [[ -n "${IFACES:-}" ]]; then
        printf '%s\n' "$IFACES"
        return 0
    fi
    if [[ -n "${IFACE:-}" ]]; then
        printf '%s\n' "$IFACE"
        return 0
    fi
    return 1
}

iface_xdp_state() {
    local iface="$1"
    local info=""
    info=$(ip -d link show dev "$iface" 2>/dev/null || true)
    [[ -n "$info" ]] || {
        printf 'missing'
        return 0
    }
    if grep -q 'xdpgeneric' <<<"$info"; then
        printf 'generic'
        return 0
    fi
    if grep -Eq 'xdp|xdpoffload' <<<"$info"; then
        printf 'native'
        return 0
    fi
    printf 'off'
}

iface_tc_egress_state() {
    local iface="$1"
    command -v tc >/dev/null 2>&1 || {
        printf 'unavailable'
        return 0
    }
    if tc filter show dev "$iface" egress pref 49152 2>/dev/null | grep -q .; then
        printf 'attached'
        return 0
    fi
    printf 'off'
}

conntrack_entry_count() {
    local map_path="$1"
    if [[ ! -e "$map_path" ]] || ! command -v bpftool >/dev/null 2>&1; then
        printf '0'
        return 0
    fi
    { bpftool -j map dump pinned "$map_path" 2>/dev/null || printf '[]\n'; } | python3 -c '
import json, sys
try:
    rows = json.load(sys.stdin)
except Exception:
    rows = []
print(len(rows) if isinstance(rows, list) else 0)
'
}

summarize_conntrack_map() {
    local map_path="$1"
    local limit="${2:-10}"
    local script
    if [[ ! -e "$map_path" ]] || ! command -v bpftool >/dev/null 2>&1; then
        echo "TOTAL|0"
        return 0
    fi
    script=$(cat <<'PY'
import json
import sys

limit = int(sys.argv[1])

try:
    rows = json.load(sys.stdin)
except Exception:
    rows = []

if not isinstance(rows, list):
    rows = []

stats = {}

for row in rows:
    key = row.get("key", [])
    if not isinstance(key, list) or len(key) < 8:
        continue
    try:
        family = int(key[0], 0) if isinstance(key[0], str) else int(key[0])
        dport = ((int(key[6], 0) if isinstance(key[6], str) else int(key[6])) << 8) | (
            int(key[7], 0) if isinstance(key[7], str) else int(key[7])
        )
    except Exception:
        continue
    entry = stats.setdefault(dport, {"total": 0, "v4": 0, "v6": 0})
    entry["total"] += 1
    if family == 2:
        entry["v4"] += 1
    elif family == 10:
        entry["v6"] += 1

print(f"TOTAL|{len(rows)}")
for dport, entry in sorted(stats.items(), key=lambda item: (-item[1]["total"], item[0]))[:limit]:
    print(f"PORT|{dport}|{entry['total']}|{entry['v4']}|{entry['v6']}")
PY
)
    { bpftool -j map dump pinned "$map_path" 2>/dev/null || printf '[]\n'; } | python3 -c "$script" "$limit"
}

render_conntrack_summary() {
    local label="$1"
    local map_path="$2"
    local limit="${3:-10}"
    local line total=0 dport count v4 v6

    printf '%s conntrack:\n' "$label"
    while IFS='|' read -r kind a b c d; do
        case "$kind" in
            TOTAL)
                total="$a"
                ;;
            PORT)
                dport="$a"
                count="$b"
                v4="$c"
                v6="$d"
                printf '  dport %-5s total=%-4s ipv4=%-4s ipv6=%s\n' "$dport" "$count" "$v4" "$v6"
                ;;
        esac
    done < <(summarize_conntrack_map "$map_path" "$limit")

    if [[ "$total" == "0" ]]; then
        printf '  (none)\n'
    fi
    printf '  total=%s\n' "$total"
}

run_backend() {
    run_admin_runtime backend "$@"
}

run_conntrack() {
    local target="all"
    local limit=10

    while [[ $# -gt 0 ]]; do
        case "$1" in
            tcp|udp|all)
                target="$1"
                shift
                ;;
            --limit)
                [[ $# -ge 2 ]] || {
                    echo "Missing value for --limit" >&2
                    exit 1
                }
                limit="$2"
                shift 2
                ;;
            -h|--help)
                usage
                exit 0
                ;;
            *)
                echo "Unknown conntrack option: $1" >&2
                exit 1
                ;;
        esac
    done

    case "$target" in
        tcp)
            render_conntrack_summary "TCP" "${BPF_PIN_DIR}/tcp_conntrack" "$limit"
            ;;
        udp)
            render_conntrack_summary "UDP" "${BPF_PIN_DIR}/udp_conntrack" "$limit"
            ;;
        all)
            render_conntrack_summary "TCP" "${BPF_PIN_DIR}/tcp_conntrack" "$limit"
            echo ""
            render_conntrack_summary "UDP" "${BPF_PIN_DIR}/udp_conntrack" "$limit"
            ;;
    esac
}

human_bytes() {
    local value="$1"
    if [[ "$value" == "-1" ]]; then
        echo "-"
        return
    fi

    awk -v bytes="$value" '
    BEGIN {
        split("B KiB MiB GiB TiB PiB", units, " ")
        val = bytes + 0
        idx = 1
        while (val >= 1024 && idx < 6) {
            val /= 1024
            idx++
        }
        if (idx == 1) {
            printf "%.0f %s", val, units[idx]
        } else {
            printf "%.2f %s", val, units[idx]
        }
    }'
}

human_bps() {
    local value="$1"
    if [[ "$value" == "-1" ]]; then
        echo "-"
        return
    fi

    awk -v bits="$value" '
    BEGIN {
        split("bps Kbps Mbps Gbps Tbps", units, " ")
        val = bits + 0
        idx = 1
        while (val >= 1000 && idx < 5) {
            val /= 1000
            idx++
        }
        if (idx == 1) {
            printf "%.0f %s", val, units[idx]
        } else {
            printf "%.2f %s", val, units[idx]
        }
    }'
}

format_rate() {
    local packet_delta="$1"
    local byte_delta="$2"
    local elapsed="$3"

    if [[ "$packet_delta" == "-1" || "$elapsed" == "0" ]]; then
        echo "-"
        return
    fi

    local pps
    pps=$(awk -v p="$packet_delta" -v t="$elapsed" 'BEGIN { printf "%.2f", p / t }')

    if [[ "$byte_delta" == "-1" ]]; then
        printf "%s pps / -" "$pps"
        return
    fi

    local bps
    bps=$(awk -v b="$byte_delta" -v t="$elapsed" 'BEGIN { printf "%.0f", (b * 8) / t }')
    printf "%s pps / %s" "$pps" "$(human_bps "$bps")"
}

read_xdp_rows() {
    [[ -e "${BPF_PIN_DIR}/pkt_counters" ]] || {
        echo "XDP counters not found at ${BPF_PIN_DIR}/pkt_counters" >&2
        exit 1
    }

    bpftool -j map dump pinned "${BPF_PIN_DIR}/pkt_counters" | python3 -c '
import json
import sys

names = [
    "TCP_NEW_ALLOW",
    "TCP_ESTABLISHED",
    "TCP_DROP",
    "UDP_PASS",
    "UDP_DROP",
    "IPv4_OTHER",
    "IPv6_ICMP",
    "FRAG_DROP",
    "ARP_NON_IP",
    "TCP_CT_MISS",
    "ICMP_DROP",
    "SYN_RATE_DROP",
    "UDP_RATE_DROP",
    "UDP_GBL_DROP",
    "TCP_NULL",
    "TCP_XMAS",
    "TCP_SYN_FIN",
    "TCP_SYN_RST",
    "TCP_RST_FIN",
    "TCP_BAD_DOFF",
    "TCP_PORT0",
    "VLAN_DROP",
    "SLOT_CALL",
    "SLOT_PASS",
    "SLOT_DROP",
    "UDP_PORT0",
    "UDP_BAD_LEN",
    "BOGON_DROP",
]

def norm(values):
    if isinstance(values, int):
        return values
    if isinstance(values, str):
        try:
            return int(values, 0)
        except ValueError:
            return 0
    if isinstance(values, list):
        return sum(norm(item) for item in values)
    if isinstance(values, dict):
        if "value" in values:
            return norm(values["value"])
        if "values" in values:
            return norm(values["values"])
        total = 0
        for key, item in values.items():
            if key in {"cpu", "index", "key"}:
                continue
            total += norm(item)
        return total
    return 0

rows = json.load(sys.stdin)
total = 0
for idx, row in enumerate(rows):
    values = row.get("values")
    if values is None:
        values = row.get("value")
    packets = norm(values)
    total += packets
    # Keep stats output resilient if counters grow before this helper is updated.
    name = names[idx] if idx < len(names) else f"COUNTER_{idx}"
    print(f"{name}|{packets}|-1")
print(f"XDP_TOTAL|{total}|-1")
'
}


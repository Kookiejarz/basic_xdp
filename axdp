#!/bin/bash
set -euo pipefail

CONFIG_FILE="/etc/auto_xdp/auto_xdp.env"
RUN_STATE_DIR="/run/auto_xdp"
BPF_PIN_DIR="/sys/fs/bpf/xdp_fw"
NFT_FAMILY="inet"
NFT_TABLE="auto_xdp"
NFT_CHAIN="input"
RUNNER_SCRIPT="/usr/local/bin/auto_xdp_start.sh"
SERVICE_NAME="xdp-port-sync"

WATCH_MODE=0
SHOW_RATES=0
INTERVAL=1
PORTS_WATCH=0
PORTS_INTERVAL=2
IFACE=""
BACKEND=""

declare -A CUR_PACKETS=()
declare -A CUR_BYTES=()
declare -A PREV_PACKETS=()
declare -A PREV_BYTES=()
declare -a ROW_ORDER=()

usage() {
    cat <<'EOF'
Usage: axdp [command] [options]

Commands:
  stats [args...]   Show Auto XDP statistics
  watch [args...]   Shorthand for: stats --watch
  ports [args...]   Show currently allowed TCP/UDP ports
  sync [args...]    Run one sync pass with automatic backend selection
  log-level [LVL]   Show or change daemon log level
  start             Start the installed service
  stop              Stop the installed service
  restart           Restart the installed service
  status            Show service status
  help              Show this help

Stats options:
  --watch              Refresh continuously
  --rates              Show packet/bit rate deltas
  --interval SEC       Refresh / delta interval in seconds (default: 1)
  --interface IFACE    Override interface autodetection

Ports options:
  --watch              Refresh continuously and detect changes
  --interval SEC       Refresh interval in seconds (default: 2)

With no command, axdp runs: stats
EOF
}

run_service_cmd() {
    local action="$1"

    if command -v systemctl >/dev/null 2>&1 && [[ -d /run/systemd/system ]]; then
        exec systemctl "$action" "$SERVICE_NAME"
    fi

    if command -v rc-service >/dev/null 2>&1; then
        exec rc-service "$SERVICE_NAME" "$action"
    fi

    echo "No supported init system detected for service control." >&2
    exit 1
}

ensure_installed() {
    local path="$1"
    [[ -x "$path" ]] || {
        echo "Missing executable: $path" >&2
        exit 1
    }
}

parse_stats_args() {
    while [[ $# -gt 0 ]]; do
        case "$1" in
            --watch)
                WATCH_MODE=1
                shift
                ;;
            --rates)
                SHOW_RATES=1
                shift
                ;;
            --interval)
                [[ $# -ge 2 ]] || {
                    echo "Missing value for --interval" >&2
                    exit 1
                }
                INTERVAL="$2"
                shift 2
                ;;
            --interface)
                [[ $# -ge 2 ]] || {
                    echo "Missing value for --interface" >&2
                    exit 1
                }
                IFACE="$2"
                shift 2
                ;;
            -h|--help)
                usage
                exit 0
                ;;
            *)
                echo "Unknown stats option: $1" >&2
                exit 1
                ;;
        esac
    done
}

load_config() {
    local cli_iface="$IFACE"
    if [[ -f "$CONFIG_FILE" ]]; then
        # shellcheck disable=SC1091
        source "$CONFIG_FILE"
    fi
    if [[ -n "$cli_iface" ]]; then
        IFACE="$cli_iface"
    fi
}

valid_log_level() {
    case "$1" in
        debug|info|warning|error)
            return 0
            ;;
        *)
            return 1
            ;;
    esac
}

set_config_var() {
    local key="$1"
    local value="$2"
    local tmp_file=""

    [[ -f "$CONFIG_FILE" ]] || {
        echo "Missing config: $CONFIG_FILE" >&2
        exit 1
    }

    tmp_file=$(mktemp)
    awk -v key="$key" -v value="$value" '
    BEGIN { updated = 0 }
    $0 ~ ("^" key "=") {
        print key "=\"" value "\""
        updated = 1
        next
    }
    { print }
    END {
        if (!updated)
            print key "=\"" value "\""
    }' "$CONFIG_FILE" > "$tmp_file"
    mv "$tmp_file" "$CONFIG_FILE"
}

run_log_level() {
    local level="${1:-}"

    load_config
    local current="${LOG_LEVEL:-info}"

    if [[ -z "$level" ]]; then
        printf "%s\n" "$current"
        return 0
    fi

    level=$(printf "%s" "$level" | tr '[:upper:]' '[:lower:]')
    valid_log_level "$level" || {
        echo "Invalid log level: $level" >&2
        echo "Valid values: debug, info, warning, error" >&2
        exit 1
    }

    set_config_var "LOG_LEVEL" "$level"
    echo "LOG_LEVEL=$level"

    if command -v systemctl >/dev/null 2>&1 && [[ -d /run/systemd/system ]]; then
        systemctl restart "$SERVICE_NAME"
        systemctl --no-pager --full status "$SERVICE_NAME"
        return 0
    fi

    if command -v rc-service >/dev/null 2>&1; then
        rc-service "$SERVICE_NAME" restart
        rc-service "$SERVICE_NAME" status
        return 0
    fi

    echo "No supported init system detected for service restart." >&2
    return 0
}

autodetect_iface() {
    if [[ -n "$IFACE" ]]; then
        return 0
    fi

    IFACE="${IFACE:-}"
    if [[ -z "$IFACE" ]]; then
        IFACE=$(ip route show default 2>/dev/null | awk '/default/ {print $5; exit}')
    fi

    [[ -n "$IFACE" ]] || {
        echo "Could not detect interface. Use --interface IFACE." >&2
        exit 1
    }
}

detect_backend() {
    local candidate=""

    if [[ -f "${RUN_STATE_DIR}/backend" ]]; then
        candidate=$(<"${RUN_STATE_DIR}/backend")
    fi

    case "$candidate" in
        xdp)
            if [[ -e "${BPF_PIN_DIR}/pkt_counters" ]] || ip -d link show dev "$IFACE" 2>/dev/null | grep -Eq 'xdp|xdpgeneric|xdpoffload'; then
                BACKEND="xdp"
                return 0
            fi
            ;;
        nftables)
            if command -v nft &>/dev/null && nft list table "$NFT_FAMILY" "$NFT_TABLE" >/dev/null 2>&1; then
                BACKEND="nftables"
                return 0
            fi
            ;;
    esac

    if [[ -e "${BPF_PIN_DIR}/pkt_counters" ]] && ip -d link show dev "$IFACE" 2>/dev/null | grep -Eq 'xdp|xdpgeneric|xdpoffload'; then
        BACKEND="xdp"
        return 0
    fi

    if command -v nft &>/dev/null && nft list table "$NFT_FAMILY" "$NFT_TABLE" >/dev/null 2>&1; then
        BACKEND="nftables"
        return 0
    fi

    if [[ -e "${BPF_PIN_DIR}/pkt_counters" ]]; then
        BACKEND="xdp"
        return 0
    fi

    echo "No active Auto XDP backend detected." >&2
    exit 1
}

human_bytes() {
    local value="$1"
    if [[ "$value" == "-1" ]]; then
        echo "-"
        return
    fi

    awk -v bytes="$value" '
    BEGIN {
        split("B KiB MiB GiB TiB PiB", units, " ")
        val = bytes + 0
        idx = 1
        while (val >= 1024 && idx < 6) {
            val /= 1024
            idx++
        }
        if (idx == 1) {
            printf "%.0f %s", val, units[idx]
        } else {
            printf "%.2f %s", val, units[idx]
        }
    }'
}

human_bps() {
    local value="$1"
    if [[ "$value" == "-1" ]]; then
        echo "-"
        return
    fi

    awk -v bits="$value" '
    BEGIN {
        split("bps Kbps Mbps Gbps Tbps", units, " ")
        val = bits + 0
        idx = 1
        while (val >= 1000 && idx < 5) {
            val /= 1000
            idx++
        }
        if (idx == 1) {
            printf "%.0f %s", val, units[idx]
        } else {
            printf "%.2f %s", val, units[idx]
        }
    }'
}

format_rate() {
    local packet_delta="$1"
    local byte_delta="$2"
    local elapsed="$3"

    if [[ "$packet_delta" == "-1" || "$elapsed" == "0" ]]; then
        echo "-"
        return
    fi

    local pps
    pps=$(awk -v p="$packet_delta" -v t="$elapsed" 'BEGIN { printf "%.2f", p / t }')

    if [[ "$byte_delta" == "-1" ]]; then
        printf "%s pps / -" "$pps"
        return
    fi

    local bps
    bps=$(awk -v b="$byte_delta" -v t="$elapsed" 'BEGIN { printf "%.0f", (b * 8) / t }')
    printf "%s pps / %s" "$pps" "$(human_bps "$bps")"
}

read_xdp_rows() {
    [[ -e "${BPF_PIN_DIR}/pkt_counters" ]] || {
        echo "XDP counters not found at ${BPF_PIN_DIR}/pkt_counters" >&2
        exit 1
    }

    bpftool -j map dump pinned "${BPF_PIN_DIR}/pkt_counters" | python3 -c '
import json
import sys

names = [
    "TCP_NEW_ALLOW",
    "TCP_ESTABLISHED",
    "TCP_DROP",
    "UDP_PASS",
    "UDP_DROP",
    "IPv4_OTHER",
    "IPv6_ICMP",
    "FRAG_DROP",
    "ARP_NON_IP",
    "TCP_CT_MISS",
    "ICMP_DROP",
    "SYN_RATE_DROP",
]

def norm(values):
    if isinstance(values, int):
        return values
    if isinstance(values, str):
        try:
            return int(values, 0)
        except ValueError:
            return 0
    if isinstance(values, list):
        return sum(norm(item) for item in values)
    if isinstance(values, dict):
        if "value" in values:
            return norm(values["value"])
        if "values" in values:
            return norm(values["values"])
        total = 0
        for key, item in values.items():
            if key in {"cpu", "index", "key"}:
                continue
            total += norm(item)
        return total
    return 0

rows = json.load(sys.stdin)
total = 0
for idx, row in enumerate(rows):
    values = row.get("values")
    if values is None:
        values = row.get("value")
    packets = norm(values)
    total += packets
    # Keep stats output resilient if counters grow before this helper is updated.
    name = names[idx] if idx < len(names) else f"COUNTER_{idx}"
    print(f"{name}|{packets}|-1")
print(f"XDP_TOTAL|{total}|-1")
'
}

read_nft_rows() {
    command -v nft >/dev/null 2>&1 || {
        echo "nft command not found" >&2
        exit 1
    }

    nft -a list chain "$NFT_FAMILY" "$NFT_TABLE" "$NFT_CHAIN" | python3 -c '
import re
import sys

text = sys.stdin.read()
match = re.search(r"counter packets (\d+) bytes (\d+) drop", text)
if not match:
    print("NFT_DROP|0|0")
    sys.exit(0)
print(f"NFT_DROP|{match.group(1)}|{match.group(2)}")
'
}

read_iface_row() {
    local stats_dir="/sys/class/net/${IFACE}/statistics"
    [[ -r "${stats_dir}/rx_packets" && -r "${stats_dir}/rx_bytes" ]] || return 0

    local packets bytes
    packets=$(<"${stats_dir}/rx_packets")
    bytes=$(<"${stats_dir}/rx_bytes")
    printf 'IFACE_RX|%s|%s\n' "$packets" "$bytes"
}

read_xdp_ports() {
    local tcp_map="${BPF_PIN_DIR}/tcp_whitelist"
    local udp_map="${BPF_PIN_DIR}/udp_whitelist"
    [[ -e "$tcp_map" && -e "$udp_map" ]] || {
        echo "XDP whitelist maps not found under ${BPF_PIN_DIR}" >&2
        exit 1
    }

    bpftool -j map dump pinned "$tcp_map" | python3 -c '
import json
import sys

def to_int(v):
    if isinstance(v, int):
        return v
    if isinstance(v, str):
        try:
            return int(v, 0)
        except ValueError:
            return 0
    return 0

def norm(v):
    if isinstance(v, (int, str)):
        return to_int(v)
    if isinstance(v, list):
        return sum(norm(i) for i in v)
    if isinstance(v, dict):
        if "value" in v:
            return norm(v["value"])
        if "values" in v:
            return norm(v["values"])
        return sum(norm(i) for i in v.values())
    return 0

def key_to_port(key):
    if isinstance(key, list):
        if len(key) >= 2:
            b0 = to_int(key[0]) & 0xFF
            b1 = to_int(key[1]) & 0xFF
            b2 = to_int(key[2]) & 0xFF if len(key) > 2 else 0
            b3 = to_int(key[3]) & 0xFF if len(key) > 3 else 0
            return b0 | (b1 << 8) | (b2 << 16) | (b3 << 24)
        return 0
    if isinstance(key, (int, str)):
        return to_int(key)
    if isinstance(key, dict):
        return norm(key)
    return 0

rows = json.load(sys.stdin)
ports = []
for row in rows:
    if norm(row.get("value", row.get("values", 0))) <= 0:
        continue
    port = key_to_port(row.get("key"))
    if 0 < port <= 65535:
        ports.append(port)
print(",".join(str(p) for p in sorted(set(ports))))
'
    bpftool -j map dump pinned "$udp_map" | python3 -c '

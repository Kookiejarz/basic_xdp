import sys

def to_int(v):
    if isinstance(v, int):
        return v
    if isinstance(v, str):
        try:
            return int(v, 0)
        except ValueError:
            return 0
    return 0

def norm(v):
    if isinstance(v, (int, str)):
        return to_int(v)
    if isinstance(v, list):
        return sum(norm(i) for i in v)
    if isinstance(v, dict):
        if "value" in v:
            return norm(v["value"])
        if "values" in v:
            return norm(v["values"])
        return sum(norm(i) for i in v.values())
    return 0

def key_to_port(key):
    if isinstance(key, list):
        if len(key) >= 2:
            b0 = to_int(key[0]) & 0xFF
            b1 = to_int(key[1]) & 0xFF

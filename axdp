read_nft_ports() {
    command -v nft >/dev/null 2>&1 || {
        echo "nft command not found" >&2
        exit 1
    }

    nft -j list set "$NFT_FAMILY" "$NFT_TABLE" tcp_ports 2>/dev/null | python3 -c '
import json
import sys
try:
    data = json.load(sys.stdin)
except Exception:
    print("")
    sys.exit(0)
ports = set()
for item in data.get("nftables", []):
    e = item.get("element")
    if not e:
        continue
    elems = e.get("elem", [])
    for v in elems:
        if isinstance(v, int) and 0 < v <= 65535:
            ports.add(v)
print(",".join(str(p) for p in sorted(ports)))

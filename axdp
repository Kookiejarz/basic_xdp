# TOML config management helpers
# Reload the running daemon via SIGHUP (no restart gap), or restart as fallback.
reload_daemon() {
    local pid
    if pid=$(systemctl show -p MainPID --value "$SERVICE_NAME" 2>/dev/null) && [[ "$pid" -gt 1 ]]; then
        kill -HUP "$pid" 2>/dev/null && return 0
    fi
    if command -v rc-service >/dev/null 2>&1; then
        rc-service "$SERVICE_NAME" restart 2>/dev/null && return 0
    fi
    command -v systemctl >/dev/null 2>&1 && systemctl restart "$SERVICE_NAME" 2>/dev/null || true
}

# Read the TOML config via Python and print as JSON (internal use).
toml_to_json() {
    python3 - "$TOML_CONFIG" <<'PY'
import sys, json, os

path = sys.argv[1]
if not os.path.exists(path):
    print("{}")
    sys.exit(0)

try:
    import tomllib
except ImportError:
    try:
        import tomli as tomllib
    except ImportError:
        import re as _re

        def _tok(s):
            items, cur, depth, in_str, esc, sc = [], [], 0, False, False, None
            for c in s[1:-1]:
                if esc: cur.append(c); esc = False; continue
                if c == '\\' and in_str: cur.append(c); esc = True; continue
                if c in ('"', "'") and not in_str: in_str = True; sc = c; cur.append(c); continue
                if c == sc and in_str: in_str = False; sc = None; cur.append(c); continue
                if not in_str:
                    if c in ('[', '{'): depth += 1
                    elif c in (']', '}'): depth -= 1
                    elif c == ',' and depth == 0: items.append(''.join(cur).strip()); cur = []; continue
                cur.append(c)
            if cur: items.append(''.join(cur).strip())
            return [i for i in items if i]

        def _val(s):
            s = s.strip()
            if s.startswith('"'):
                try: return json.loads(s)
                except Exception: return s[1:-1]
            if s.startswith("'"): return s[1:-1]
            if s == 'true': return True
            if s == 'false': return False
            if s.startswith('['): return [_val(i) for i in _tok(s)]
            if s.startswith('{'):
                return {k.strip(): _val(v) for k, sep, v in
                        (p.partition('=') for p in _tok(s)) if sep}
            try: return int(s)
            except ValueError: pass
            try: return float(s)
            except ValueError: return s

        def _parse_toml(text):
            root = cur = {}
            for raw in text.splitlines():
                line = raw.strip()
                if not line or line.startswith('#'): continue
                m = _re.match(r'^\[([^\[\]]+)\]$', line)
                if m:
                    cur = root
                    for k in m.group(1).split('.'): cur = cur.setdefault(k.strip(), {})
                    continue
                m = _re.match(r'^([A-Za-z0-9_-]+)\s*=\s*(.+)$', line)
                if m: cur[m.group(1)] = _val(m.group(2).strip())
            return root

        class tomllib:
            @staticmethod
            def load(f): return _parse_toml(f.read().decode())

with open(path, "rb") as f:
    data = tomllib.load(f)
print(json.dumps(data))
PY
}

# Write the config dict (JSON on stdin) back to the TOML file.
json_to_toml() {
    local path="$TOML_CONFIG"
    local script
    script=$(cat <<'PY'
import json
import math
import os
import re
import sys

path = sys.argv[1]
data = json.load(sys.stdin)

_BARE_KEY_RE = re.compile(r"^[A-Za-z0-9_-]+$")


def fmt_key(key):
    key = str(key)
    return key if _BARE_KEY_RE.match(key) else json.dumps(key)


def fmt_path(parts):
    return ".".join(fmt_key(part) for part in parts)


def is_array_of_tables(value):
    return isinstance(value, list) and value and all(isinstance(item, dict) for item in value)


def fmt_value(value):
    if isinstance(value, bool):
        return "true" if value else "false"
    if isinstance(value, int) and not isinstance(value, bool):
        return str(value)
    if isinstance(value, float):
        if math.isnan(value) or math.isinf(value):
            raise ValueError("TOML does not support NaN or infinity")
        return repr(value)
    if isinstance(value, str):
        return json.dumps(value)
    if isinstance(value, list):
        return "[" + ", ".join(fmt_value(item) for item in value) + "]"
    if isinstance(value, dict):
        inner = ", ".join(f"{fmt_key(k)} = {fmt_value(v)}" for k, v in value.items())
        return "{ " + inner + " }"
    raise TypeError(f"unsupported TOML value: {type(value).__name__}")


def emit_table_body(table, path_parts):
    lines = []
    scalar_items = []
    array_table_items = []
    table_items = []

    for key, value in table.items():
        if is_array_of_tables(value):
            array_table_items.append((key, value))
        elif isinstance(value, dict):
            table_items.append((key, value))
        else:
            scalar_items.append((key, value))

    for key, value in scalar_items:
        lines.append(f"{fmt_key(key)} = {fmt_value(value)}")

    for key, value in array_table_items:
        if lines:
            lines.append("")
        child_path = path_parts + [key]
        for idx, item in enumerate(value):
            if idx > 0:
                lines.append("")
            lines.append(f"[[{fmt_path(child_path)}]]")
            lines.extend(emit_table_body(item, child_path))

    for key, value in table_items:
        if lines:
            lines.append("")
        child_path = path_parts + [key]
        lines.append(f"[{fmt_path(child_path)}]")
        lines.extend(emit_table_body(value, child_path))

    return lines


lines = emit_table_body(data, [])

os.makedirs(os.path.dirname(path), exist_ok=True)
with open(path, "w") as f:
    f.write("\n".join(lines).rstrip() + "\n")
PY
)
    python3 -c "$script" "$path"
}

mutate_toml_json() {
    local json script
    json=$(toml_to_json) || return 1
    script=$(cat) || return 1
    printf '%s\n' "$json" | python3 -c "$script" "$@"
}


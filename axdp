            toml_to_json | python3 -c '
import sys, json
cfg = json.load(sys.stdin)
perm = cfg.get("permanent_ports", {})
tcp = perm.get("tcp", [])
udp = perm.get("udp", [])
sctp = perm.get("sctp", [])
if not tcp and not udp and not sctp:
    print("  (none)")
else:
    for p in sorted(tcp): print(f"  TCP  {p}")
    for p in sorted(udp): print(f"  UDP  {p}")
    for p in sorted(sctp): print(f"  SCTP {p}")
'
            ;;
        add)
            local proto="${1:-}"
            local port="${2:-}"
            local label="${3:-config}"
            [[ -n "$proto" && -n "$port" ]] || {
                echo "Usage: axdp permanent add tcp|udp|sctp PORT [LABEL]" >&2; exit 1
            }
            [[ "$proto" == "tcp" || "$proto" == "udp" || "$proto" == "sctp" ]] || {
                echo "proto must be tcp, udp, or sctp" >&2; exit 1
            }
            [[ -f "$TOML_CONFIG" ]] || run_config init
            mutate_toml_json "$proto" "$port" <<'PY' | json_to_toml
import sys, json
data = json.load(sys.stdin)
proto, port = sys.argv[1], int(sys.argv[2])
perm = data.setdefault("permanent_ports", {"tcp": [], "udp": [], "sctp": []})
lst = perm.setdefault(proto, [])
if port not in lst:
    lst.append(port)
    lst.sort()
print(json.dumps(data))
PY
            echo "Added permanent: $proto/$port"
            reload_daemon
            ;;
        del)
            local proto="${1:-}"
            local port="${2:-}"
            [[ -n "$proto" && -n "$port" ]] || {
                echo "Usage: axdp permanent del tcp|udp|sctp PORT" >&2; exit 1
            }
            [[ "$proto" == "tcp" || "$proto" == "udp" || "$proto" == "sctp" ]] || {
                echo "proto must be tcp, udp, or sctp" >&2; exit 1
            }
            mutate_toml_json "$proto" "$port" <<'PY' | json_to_toml
import sys, json
data = json.load(sys.stdin)
proto, port = sys.argv[1], int(sys.argv[2])
perm = data.setdefault("permanent_ports", {"tcp": [], "udp": [], "sctp": []})
perm[proto] = [p for p in perm.get(proto, []) if p != port]
print(json.dumps(data))
PY
            echo "Removed permanent: $proto/$port"
            reload_daemon
            ;;
        -h|--help)
            echo "Usage: axdp permanent list|add tcp|udp|sctp PORT [LABEL]|del tcp|udp|sctp PORT"
            ;;
        *)
            echo "Unknown permanent subcommand: $sub" >&2; exit 1 ;;
    esac
}

run_slot() {
    local sub="${1:-list}"; shift || true
    local HANDLERS_DIR="${INSTALL_DIR}/handlers"
    local SLOT_PIN_DIR="${BPF_PIN_DIR}/handlers"

    case "$sub" in
        list)
            if [[ ! -e "${BPF_PIN_DIR}/proto_handlers" ]]; then
                echo "XDP not loaded (proto_handlers map not found)."
                exit 1
            fi

            echo "Loaded handlers:"
            local found=0
            for pin in "${SLOT_PIN_DIR}"/proto_*; do
                [[ -e "$pin" ]] || continue
                local proto="${pin##*/proto_}"
                local name
                name=$(bpftool prog show pinned "$pin" 2>/dev/null \
                    | grep -oP 'name \K\S+' || echo "custom")
                printf "  proto %-5s %s\n" "$proto" "$name"
                found=1
            done
            [[ $found -eq 1 ]] || echo "  (none)"

            echo ""
            echo "Available handlers:"
            local -A BUILTIN=([gre]="47  ${HANDLERS_DIR}/gre_handler.o"
                              [esp]="50  ${HANDLERS_DIR}/esp_handler.o"
                              [sctp]="132 ${HANDLERS_DIR}/sctp_handler.o")
            for name in gre esp sctp; do
                local info="${BUILTIN[$name]}"
                local proto="${info%% *}"
                local obj="${info#* }"
                obj="${obj# }"
                if [[ -f "$obj" ]]; then
                    local pin="${SLOT_PIN_DIR}/proto_${proto}"
                    if [[ -e "$pin" ]]; then
                        printf "  %-6s (proto %s)  [loaded]\n" "$name" "$proto"
                    else
                        printf "  %-6s (proto %s)\n" "$name" "$proto"
                    fi
                else
                    printf "  %-6s (proto %s)  [.o not found: %s]\n" "$name" "$proto" "$obj"
                fi
            done
            for obj in "${HANDLERS_DIR}"/*.o; do
                [[ -f "$obj" ]] || continue
                local base="${obj##*/}"
                case "$base" in gre_handler.o|esp_handler.o|sctp_handler.o) continue ;; esac
                printf "  custom  %s\n" "$obj"
            done
            ;;

        load)
            local name_or_proto="${1:-}"
            local custom_path="${2:-}"
            [[ -n "$name_or_proto" ]] || {
                echo "Usage: axdp slot load NAME|PROTO [PATH]" >&2; exit 1
            }

            local proto obj_path builtin_name=""
            case "$name_or_proto" in
                gre)  proto=47;  obj_path="${HANDLERS_DIR}/gre_handler.o";  builtin_name="gre"  ;;
                esp)  proto=50;  obj_path="${HANDLERS_DIR}/esp_handler.o";  builtin_name="esp"  ;;
                sctp) proto=132; obj_path="${HANDLERS_DIR}/sctp_handler.o"; builtin_name="sctp" ;;
                *[0-9]*)
                    proto="$name_or_proto"
                    obj_path="$custom_path"
                    [[ -n "$obj_path" ]] || {
                        echo "Custom handler requires a .o path: axdp slot load PROTO /path/to/handler.o" >&2
                        exit 1
                    }
                    ;;
                *)
                    echo "Unknown handler: $name_or_proto (built-in: gre, esp, sctp)" >&2
                    exit 1
                    ;;
            esac

            [[ -f "$obj_path" ]] || {
                echo "Handler object not found: $obj_path" >&2; exit 1
            }
            [[ -e "${BPF_PIN_DIR}/slot_ctx_map" ]] || {
                echo "XDP not loaded (slot_ctx_map not found). Run setup first." >&2; exit 1
            }

            mkdir -p "$SLOT_PIN_DIR"
            local pin_path="${SLOT_PIN_DIR}/proto_${proto}"
            local -a load_args=(
                map name slot_ctx_map pinned "${BPF_PIN_DIR}/slot_ctx_map"
            )

            if [[ "$proto" == "132" && "$obj_path" == "${HANDLERS_DIR}/sctp_handler.o" ]]; then
                [[ -e "${BPF_PIN_DIR}/sctp_whitelist" ]] || {
                    echo "XDP not loaded completely (sctp_whitelist map not found)." >&2
                    exit 1
                }
                [[ -e "${BPF_PIN_DIR}/sctp_conntrack" ]] || {
                    echo "XDP not loaded completely (sctp_conntrack map not found)." >&2
                    exit 1
                }
                load_args+=(
                    map name sctp_whitelist pinned "${BPF_PIN_DIR}/sctp_whitelist"
                    map name sctp_conntrack pinned "${BPF_PIN_DIR}/sctp_conntrack"
                )
            fi

            # Reuse the pinned maps so the handler shares runtime state with the main program.
            bpftool prog load "$obj_path" "$pin_path" type xdp \
                "${load_args[@]}" || {
                echo "Failed to load $obj_path" >&2; exit 1
            }

            # Register in proto_handlers prog_array.
            local k
            k=$(printf '%d 0 0 0' "$proto")
            bpftool map update pinned "${BPF_PIN_DIR}/proto_handlers" \
                key $k value pinned "$pin_path" || {
                echo "Failed to register handler for proto $proto" >&2
                rm -f "$pin_path"
                exit 1
            }

            echo "Loaded handler for proto $proto from $obj_path"

            # Persist to TOML config.
            [[ -f "$TOML_CONFIG" ]] || run_config init
            if [[ -n "$builtin_name" ]]; then
                mutate_toml_json "$builtin_name" <<'PY' | json_to_toml
import sys, json
data = json.load(sys.stdin)
name = sys.argv[1]
slots = data.setdefault("slots", {})
enabled = slots.setdefault("enabled", [])
if name not in enabled:
    enabled.append(name)
print(json.dumps(data))
PY
            else
                mutate_toml_json "$proto" "$obj_path" <<'PY' | json_to_toml
import sys, json
data = json.load(sys.stdin)
proto, path = int(sys.argv[1]), sys.argv[2]
slots = data.setdefault("slots", {})
enabled = slots.setdefault("enabled", [])
enabled = [e for e in enabled if not (isinstance(e, dict) and e.get("proto") == proto)]
enabled.append({"proto": proto, "path": path})
slots["enabled"] = enabled
print(json.dumps(data))
PY
            fi
            echo "  config: $TOML_CONFIG"
            ;;

        unload)
            local name_or_proto="${1:-}"
            [[ -n "$name_or_proto" ]] || {
                echo "Usage: axdp slot unload NAME|PROTO" >&2; exit 1
            }

            local proto
            if [[ "$name_or_proto" =~ ^[0-9]+$ ]]; then
                proto="$name_or_proto"
            else
                proto=""
                for pin in "${SLOT_PIN_DIR}"/proto_*; do
                    [[ -e "$pin" ]] || continue
                    local pname
                    pname=$(bpftool prog show pinned "$pin" 2>/dev/null \
                        | grep -oP 'name \K\S+' || true)
                    if [[ "$pname" == "$name_or_proto" || "$pname" == *"_${name_or_proto}_"* || "$pname" == *"_${name_or_proto}" ]]; then
                        proto="${pin##*/proto_}"
                        break
                    fi
                done
                [[ -n "$proto" ]] || {
                    echo "No loaded handler matches: $name_or_proto" >&2; exit 1
                }
            fi

            local k
            k=$(printf '%d 0 0 0' "$proto")
            bpftool map delete pinned "${BPF_PIN_DIR}/proto_handlers" \
                key $k 2>/dev/null || true

            rm -f "${SLOT_PIN_DIR}/proto_${proto}"
            echo "Unloaded handler for proto $proto"

            # Remove from TOML config if it exists.
            if [[ -f "$TOML_CONFIG" ]]; then
                mutate_toml_json "$proto" <<'PY' | json_to_toml
import sys, json
data = json.load(sys.stdin)
proto = int(sys.argv[1])
BUILTIN = {47: "gre", 50: "esp", 132: "sctp"}
builtin_name = BUILTIN.get(proto)
slots = data.setdefault("slots", {})
enabled = slots.get("enabled", [])
new_enabled = [
    e for e in enabled
    if not (isinstance(e, str) and e == builtin_name)
    and not (isinstance(e, dict) and e.get("proto") == proto)
]
slots["enabled"] = new_enabled
print(json.dumps(data))
PY
                echo "  config: $TOML_CONFIG"
            fi
            ;;

        *)
            echo "Usage: axdp slot list|load NAME|PROTO [PATH]|unload NAME|PROTO" >&2
            exit 1
            ;;
    esac
}

main() {
    local cmd="${1:-stats}"

    case "$cmd" in
        stats)
            shift || true
            run_stats "$@"
            ;;
        watch)
            shift || true
            run_stats --watch "$@"
            ;;
        ports)
            shift || true
            run_ports "$@"
            ;;
        backend)
            shift || true
            run_backend "$@"
            ;;
        conntrack)
            shift || true
            run_conntrack "$@"
            ;;
        sync)
            shift || true
            ensure_installed "$RUNNER_SCRIPT"
            exec "$RUNNER_SCRIPT" --sync-once "$@"
            ;;
        check-update)
            shift || true
            run_check_update "$@"
            ;;
        log-level)
            shift || true
            run_log_level "$@"
            ;;
        config)
            shift || true
            run_config "$@"
            ;;
        trust)
            shift || true
            run_trust "$@"
            ;;
        acl)
            shift || true
            run_acl "$@"
            ;;
        permanent)
            shift || true
            run_permanent "$@"
            ;;
        slot)
            shift || true
            run_slot "$@"
            ;;
        start|stop|restart|status)
            shift || true
            run_service_cmd "$cmd"
            ;;
        help|-h|--help)
            usage
            ;;
        *)
            run_stats "$@"
            ;;
    esac
}

if [[ "${BASH_SOURCE[0]:-}" == "$0" ]]; then
    main "$@"
fi

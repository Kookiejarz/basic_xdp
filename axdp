parse_ports_args() {
    while [[ $# -gt 0 ]]; do
        case "$1" in
            --watch)
                PORTS_WATCH=1
                shift
                ;;
            --interval)
                [[ $# -ge 2 ]] || {
                    echo "Missing value for --interval" >&2
                    exit 1
                }
                PORTS_INTERVAL="$2"
                shift 2
                ;;
            -h|--help)
